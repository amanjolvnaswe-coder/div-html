<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Div</title>
</head>
<body>
    <div style="display: grid;grid-template-columns: repeat(4,1fr);column-gap: 20px; row-gap: 15px;">
        <div style="background-color: blue;">col-1</div>
        <div style="background-color: blue;">col-2</div>
        <div style="background-color: blue;">col-3</div>
        <div style="background-color: blue;">col-4</div>
        <div style="background-color: blue;">col-5</div>
        <div style="background-color: blue;">col-6</div>
        <div style="background-color: blue;">col-7</div>
        <div style="background-color: blue;">col-8</div>
    </div>
</body>
</html>
