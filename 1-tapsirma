<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Div</title>
</head>
<body>
    <div style="display: grid; grid-template-columns: 250px 1fr;">
        <div style="background-color:green;">250px</div>
        <div style="background-color: rgb(226, 43, 226);" >1fr</div>
    </div>

    <br>
    <div style="display: grid; grid-template-columns:1fr 3fr 1fr;">
        <div style="background-color: aqua;">box-1</div>
        <div style="background-color: rgb(0, 189, 0);">box-2</div>
        <div style="background-color: blueviolet;">box-3</div>
    </div>

    <br>
    <div style="display: grid; grid-template-columns: repeat(3,1fr);">
        <div style="background-color: aquamarine;">1fr</div>
        <div style="background-color: rgb(255, 236, 127);">1fr</div>
        <div style="background-color: rgb(255, 127, 202);">1fr</div>          
    </div>

    <br>
    <div style="display: grid; grid-template-columns: 100px 1fr 2fr 50px;">
        <div style="background-color: blue;">100px;</div>
        <div style="background-color: bisque;">1fr;</div>
        <div style="background-color: brown;">2fr;</div>
        <div style="background-color: green;">50px;</div>

        
    </div>
</body>
</html>
